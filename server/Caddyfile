# Replace api.mytummyhurts.app with your real API domain. Caddy auto-provisions
# TLS via Let's Encrypt and reverse-proxies to the NestJS api service.
api.mytummyhurts.app {
	encode gzip
	reverse_proxy api:3000
}

# Signed scan image URLs must be reachable by the mobile app. Point
# S3_ENDPOINT at this public HTTPS host in production, e.g.
# S3_ENDPOINT=https://storage.mytummyhurts.app
storage.mytummyhurts.app {
	encode gzip
	reverse_proxy minio:9000
}

# Marketing site — static files mounted from server/landing (see
# docker-compose.prod.yml). Caddy auto-provisions TLS for the apex.
mytummyhurts.app {
    encode gzip zstd
    root * /var/www/landing
    header /assets/* Cache-Control "public, max-age=604800"
    file_server
}

www.mytummyhurts.app {
    redir https://mytummyhurts.app{uri} permanent
}
