# ---- Core ----
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
HTTP_BODY_LIMIT=25mb
# The server refuses to start without OPENAI_API_KEY unless DEMO_MODE=true
# explicitly opts in to fabricated demo extractions. Never true in production.
DEMO_MODE=false

# ---- Database (Phase 1) ----
# Run migrations with DATABASE_ADMIN_URL first. Then run the API with the
# non-BYPASSRLS app role and service operations with the BYPASSRLS service role.
DATABASE_URL=postgres://mth_app:mth_app@localhost:5432/mth
DATABASE_SERVICE_URL=postgres://mth_service:mth_service@localhost:5432/mth
DATABASE_ADMIN_URL=postgres://mth:mth@localhost:5432/mth
POSTGRES_USER=mth
POSTGRES_PASSWORD=mth
POSTGRES_DB=mth

# ---- Auth (Phase 2) ----
JWT_ACCESS_SECRET=
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_DAYS=60
APPLE_BUNDLE_ID=com.thomascadle.mytummyhurts
GOOGLE_IOS_CLIENT_ID=
GOOGLE_WEB_CLIENT_ID=
ADMIN_API_SECRET=

# ---- OpenAI / extraction (Phase 5) ----
OPENAI_API_KEY=
OPENAI_EXTRACTION_MODEL=gpt-5.4-mini
OPENAI_IMAGE_EXTRACTION_MODEL=gpt-5.4-mini
# Menu work is split into vision transcription and bounded text analysis.
# Each stage uses the same fast current model by default and can be tuned separately.
OPENAI_MENU_TRANSCRIPTION_MODEL=gpt-5.4-mini
OPENAI_MENU_ANALYSIS_MODEL=gpt-5.4-mini
# Cheap food-vs-menu router (image detail low, tiny output cap).
OPENAI_CLASSIFICATION_MODEL=gpt-5-nano
OPENAI_CLASSIFICATION_MAX_OUTPUT_TOKENS=300
# Legacy: no longer used by the scan pipeline (the LLM normalization pass was
# removed); still the fallback default for taxonomy + last-bad-meal extraction.
OPENAI_NORMALIZATION_MODEL=gpt-4.1-mini
OPENAI_EXTRACTION_PROMPT_VERSION=mytummyhurts_extract_v4
OPENAI_MENU_PROMPT_VERSION=mytummyhurts_menu_v5
OPENAI_IMAGE_DETAIL=high
OPENAI_MENU_IMAGE_DETAIL=high
OPENAI_TIMEOUT_MS=30000
OPENAI_MENU_TRANSCRIPTION_TIMEOUT_MS=60000
OPENAI_MENU_ANALYSIS_TIMEOUT_MS=60000
OPENAI_EXTRACTION_TEMPERATURE=
OPENAI_TEXT_MAX_OUTPUT_TOKENS=6000
OPENAI_IMAGE_MAX_OUTPUT_TOKENS=6000
OPENAI_MENU_TRANSCRIPTION_MAX_OUTPUT_TOKENS=6000
OPENAI_MENU_ANALYSIS_MAX_OUTPUT_TOKENS=6000
# Analysis batch size is capped at 20; shared transcription/analysis concurrency at 4.
OPENAI_MENU_ANALYSIS_BATCH_SIZE=12
OPENAI_MENU_STAGE_CONCURRENCY=2
# The in-process worker polls the durable Postgres queue; concurrency is capped at 10.
SCAN_ANALYSIS_WORKER_ENABLED=true
SCAN_ANALYSIS_WORKER_CONCURRENCY=2
MENU_LLM_BANDS=on
# Same lever for food scans; bands are also skipped automatically when
# mechanism-only scoring (which discards them) is enabled.
FOOD_LLM_BANDS=on
OPENAI_JUDGE_MODEL=gpt-4.1-mini
OPENAI_TAXONOMY_MODEL=gpt-4.1-mini
OPENAI_TAXONOMY_TIMEOUT_MS=15000
# Total wall-clock budget for per-ingredient LLM taxonomy work. Remaining
# ingredients use deterministic classification when the budget expires.
OPENAI_TAXONOMY_PHASE_BUDGET_MS=30000
OPENAI_LAST_BAD_MEAL_EXTRACTION_MODEL=gpt-4.1-mini
OPENAI_LAST_BAD_MEAL_EXTRACTION_TIMEOUT_MS=15000
OPENAI_LAST_BAD_MEAL_EXTRACTION_MAX_OUTPUT_TOKENS=900
OPENAI_RISK_ADJUDICATION_MODEL=gpt-5-mini
OPENAI_RISK_ADJUDICATION_PROMPT_VERSION=mytummyhurts_risk_adjudication_v2
OPENAI_RISK_ADJUDICATION_TIMEOUT_MS=30000
OPENAI_RISK_ADJUDICATION_MAX_OUTPUT_TOKENS=3000
SCAN_RISK_ADJUDICATION_ENABLED=false
SCAN_MECHANISM_SCORING_V1_ENABLED=false

# Parallel evidence-grounded concern engine. It requires OPENAI_API_KEY and
# never changes the served scan while in shadow mode. Set off as an immediate
# cost/operations kill switch. Batch size is capped at 20, concurrent runs at
# 10, and queued runs at 200; invalid positive-integer settings use these shown
# defaults.
CONCERN_V1_SHADOW_ENABLED=on
OPENAI_CONCERN_MECHANISM_MODEL=gpt-5.4-mini
OPENAI_CONCERN_ADJUDICATION_MODEL=gpt-5.4-mini
OPENAI_CONCERN_VERIFICATION_MODEL=gpt-5.4-mini
OPENAI_CONCERN_TIMEOUT_MS=45000
OPENAI_CONCERN_MAX_OUTPUT_TOKENS=6000
OPENAI_CONCERN_BATCH_SIZE=12
CONCERN_V1_MAX_CONCURRENT_RUNS=2
CONCERN_V1_MAX_QUEUED_RUNS=20
CONCERN_V1_QUEUE_TIMEOUT_MS=30000

# ---- Embeddings / RAG (Phase 7) ----
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
RAG_RETRIEVAL_ENABLED=true
RAG_INFLUENCE_ENABLED=false
RAG_INFLUENCE_MAX_DELTA=5

# ---- Scan caps ----
SCAN_DAILY_SOFT_CAP=30
SCAN_DAILY_HARD_CAP=60

# ---- Billing / RevenueCat ----
REVENUECAT_WEBHOOK_SECRET=
REVENUECAT_REST_API_KEY=
REVENUECAT_API_BASE_URL=https://api.revenuecat.com/v1
REVENUECAT_ENTITLEMENT_ID=MyTummyHurts Pro
REVENUECAT_MONTHLY_PRODUCT_ID=monthly
REVENUECAT_ANNUAL_PRODUCT_ID=annual
# Optional map, e.g. monthly:1000,annual:1000
REVENUECAT_PRODUCT_ALLOWANCES=
# Keep false unless a temporary internal build needs legacy client-authoritative top-ups.
ALLOW_UNVERIFIED_CLIENT_TOPUPS=false

# ---- Object storage / MinIO (Phase 4) ----
# Local: http://localhost:9000. Production: public Caddy host used in signed URLs,
# e.g. https://storage.mytummyhurts.app.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=meal-images
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_FORCE_PATH_STYLE=true

# ---- Push + scheduled jobs (Phase 9) ----
APNS_KEY_ID=
APPLE_TEAM_ID=
APNS_AUTH_KEY=
IOS_BUNDLE_ID=com.thomascadle.mytummyhurts
FOLLOWUP_DISPATCH_SECRET=
MAINTENANCE_DISPATCH_SECRET=
LEARNING_WORKER_ENABLED=true
MAINTENANCE_ENABLED=true
TRACE_RETENTION_DAYS=30
RETRIEVAL_RETENTION_DAYS=90
MONTHLY_COST_CAP_USD_MICROS=0

# ---- Observability (Phase 9) ----
LANGSMITH_TRACING=false
SENTRY_DSN=
