{
  "name": "@mth/server",
  "version": "0.1.0",
  "private": true,
  "description": "MyTummyHurts self-hosted NestJS backend (replaces Supabase Edge Functions)",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "test": "vitest run",
    "db:migrate": "node scripts/migrate.mjs",
    "db:isolation-check": "node scripts/isolation-check.mjs",
    "eval": "node scripts/eval/run.mjs",
    "eval:scans": "node scripts/eval/run-scan-evals.mjs",
    "eval:retrieval": "node scripts/eval/run-retrieval-evals.mjs",
    "eval:langsmith": "node scripts/eval/run-langsmith-evals.mjs",
    "eval:all": "npm run build && npm run eval && npm run eval:retrieval && npm run eval:scans",
    "rag:seed": "node scripts/rag/seed-corpus.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@langchain/core": "^1.2.1",
    "@langchain/langgraph": "^1.4.7",
    "@langchain/openai": "^1.5.3",
    "@mth/shared-domain": "file:../packages/shared-domain",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/schedule": "^4.1.2",
    "@nestjs/terminus": "^10.2.3",
    "@nestjs/throttler": "^6.3.0",
    "@sentry/node": "^8.47.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.36.4",
    "jose": "^5.9.6",
    "langsmith": "^0.7.14",
    "nestjs-pino": "^4.1.0",
    "openevals": "^0.2.0",
    "pino-http": "^10.3.0",
    "postgres": "^3.4.5",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@swc/core": "^1.10.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/node": "^20.17.0",
    "drizzle-kit": "^0.28.1",
    "typescript": "^5.6.3",
    "unplugin-swc": "^1.5.1",
    "vitest": "^2.1.8"
  }
}
